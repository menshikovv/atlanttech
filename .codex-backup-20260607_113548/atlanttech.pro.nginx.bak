server {
    server_name atlanttech.pro www.atlanttech.pro;

    location = /payments/robokassa/result {
        limit_except GET POST { deny all; }
        proxy_pass http://80.64.17.207:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_next_upstream off;
        proxy_buffering off;
    }

    location = /payments/robokassa/success {
        limit_except GET POST { deny all; }
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_next_upstream off;
        proxy_buffering off;
    }

    location = /payments/robokassa/fail {
        limit_except GET POST { deny all; }
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_next_upstream off;
        proxy_buffering off;
    }

    location /_next/static {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location = /favicon.ico {
        alias /root/apps/twizz-project/public/favicon.ico;
        expires 30d;
        add_header Cache-Control "public";
        access_log off;
        log_not_found off;
    }

    location = /robots.txt {
        alias /root/apps/twizz-project/public/robots.txt;
        expires 1d;
        add_header Cache-Control "public";
        access_log off;
        log_not_found off;
    }

    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    access_log /var/log/nginx/atlanttech-pro.access.log;
    error_log /var/log/nginx/atlanttech-pro.error.log;

    listen [::]:443 ssl ipv6only=on;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/atlanttech.pro/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/atlanttech.pro/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = www.atlanttech.pro) {
        return 301 https://$host$request_uri;
    }

    if ($host = atlanttech.pro) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    server_name atlanttech.pro www.atlanttech.pro;
    return 404;
}
